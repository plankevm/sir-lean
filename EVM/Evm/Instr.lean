def serializeSystemInstr : SystemOp → UInt8
  | .STOP         => 0x00
  | .CREATE       => 0xf0
  | .CALL         => 0xf1
  | .CALLCODE     => 0xf2
  | .RETURN       => 0xf3
  | .DELEGATECALL => 0xf4
  | .CREATE2      => 0xf5
  | .STATICCALL   => 0xfa
  | .REVERT       => 0xfd
  | .INVALID      => 0xfe
  | .SELFDESTRUCT => 0xff

def serializeInstr : Operation → UInt8
  | .ArithLogic a => serializeArithLogicInstr a
  | .KECCAK256    => 0x20
  | .Env e        => serializeEnvInstr e
  | .Block b      => serializeBlockInstr b
  | .Smsf m       => serializeSmsfInstr m
  | .Push p       => serializePushInstr p
  | .Dup d        => serializeDupInstr d
  | .Swap e       => serializeSwapInstr e
  | .Log l        => serializeLogInstr l
  | .System s     => serializeSystemInstr s

